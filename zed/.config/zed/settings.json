{
  // =========================
  // 基础设置
  // =========================
  "auto_update": false,
  "auto_install_extensions": {
    "basher": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "html": true,
    "emmet": true,
    "lua": true,
    "toml": true,
    "xml": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "proxy": "http://127.0.0.1:7897",

  // =========================
  // 主题
  // =========================
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "base_keymap": "VSCode",

  // =========================
  // 字体
  // =========================
  "ui_font_family": "BerkeleyMono Nerd Font",
  "ui_font_size": 14.0,
  "ui_font_weight": 300.0,
  "buffer_font_family": "BerkeleyMono Nerd Font",
  "buffer_font_size": 14.0,
  "buffer_font_weight": 300,
  "buffer_font_features": { "calt": false },
  "buffer_line_height": { "custom": 1.5 },
  "minimap": { "show": "never" },

  // =========================
  // 编辑器核心设置
  // =========================
  "always_treat_brackets_as_autoclosed": true,
  "auto_signature_help": false,
  "show_completion_documentation": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 2,
      "max_severity": "warning",
    },
  },
  "hide_mouse": "on_typing_and_movement",
  "inline_code_actions": false,
  "middle_click_paste": false,
  "vertical_scroll_margin": 0,
  "restore_on_startup": "last_session",
  "restore_on_file_reopen": true,
  "autosave": "on_window_change",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": false,
  "preferred_line_length": 100,
  "soft_wrap": "preferred_line_length",
  "current_line_highlight": "none",
  "tab_size": 4,
  "hard_tabs": false,
  "use_autoclose": true,

  // =========================
  // Git
  // =========================
  "git": {
    "inline_blame": { "enabled": false },
    "git_gutter": "tracked_files",
  },

  // =========================
  // Vim
  // =========================
  "vim_mode": true,
  "vim": {
    "default_mode": "normal",
    "toggle_relative_line_numbers": false,
    "use_system_clipboard": "always",
    "use_smartcase_find": false,
    "gdefault": false,
    "highlight_on_yank_duration": 200,
    "custom_digraphs": {},
    "cursor_shape": {
      "normal": "block",
      "replace": "underline",
      "visual": "block",
      "insert": "bar",
    },
  },
  "relative_line_numbers": "enabled",
  "scrollbar": { "show": "never" },

  // =========================
  // Terminal
  // =========================
  "terminal": {
    "font_family": "BerkeleyMono Nerd Font",
    "font_size": 13.0,
    "line_height": "standard",
    "dock": "bottom",
    "copy_on_select": true,
    "env": {
      "EDITOR": "zed --wait",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
  },

  // =========================
  // UI
  // =========================
  "colorize_brackets": true,
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": true,
    "agent_review": true,
    "code_actions": true,
  },
  "tabs": {
    "git_status": true,
    "close_position": "right",
    "file_icons": true,
    "show_close_button": "hover",
    "activate_on_close": "history",
    "show_diagnostics": "all",
  },
  "project_panel": {
    "entry_spacing": "standard",
  },
  "status_bar": {
    "active_language_button": true,
  },
  "hover_popover_enabled": true,
  "hover_popover_delay": 300,

  // =========================
  // 完成与提示
  // =========================
  "multi_cursor_modifier": "alt",
  "show_completions_on_input": true,
  "inlay_hints": {
    "enabled": true,
    "show_other_hints": false,
    "show_parameter_hints": false,
    "show_type_hints": false,
    "show_value_hints": true,
  },

  // =========================
  // AI & 代码预测
  // =========================
  "edit_predictions": {
    "mode": "subtle",
  },
  "show_edit_predictions": true,
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "ctx7sk-5e9fa061-e966-413f-b425-debfdc8f67d0",
      },
    },
  },
  "agent_servers": {
    "Qwen Code": {
      "type": "custom",
      "command": "qwen",
      "args": ["--experimental-acp"],
      "env": {},
    },
    "Kimi Code CLI": {
      "type": "custom",
      "command": "kimi",
      "args": ["acp"],
      "env": {},
    },
  },
  "agent": {
    "inline_assistant_use_streaming_tools": true,
    "enabled": true,
    "button": true,
    "dock": "right",
    "flexible": true,
    "sidebar_side": "left",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4",
      "enable_thinking": false,
    },
  },

  // =========================
  // 格式化 & LSP
  // =========================
  "format_on_save": "on",
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {},
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "imports": {
          "merge": { "glob": false },
          "granularity": {
            "enforce": true,
            "group": "module",
          },
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },

  // =========================
  // 语言特定配置
  // =========================
  "languages": {
    "Python": {
      "language_servers": ["!basedpyright", "ty", "ruff"],
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
        { "language_server": { "name": "ruff" } },
      ],
    },
    "Rust": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "rustfmt",
          "arguments": [],
        },
      },
    },
    "TypeScript": {
      "formatter": "prettier",
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true,
      },
    },
    "YAML": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "JavaScript": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "JSONC": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "JSON": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "HTML": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "CSS": {
      "formatter": "prettier",
    },
  },

  // =========================
  // 文件过滤
  // =========================
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSONC": ["**/.zed/**/*.json", "**/zed/**/*.json", "**/Zed/**/*.json", "**/.vscode/**/*.json", "tsconfig*.json", "*.code-snippets"],
    "Shell Script": [".env.*"],
  },
}
